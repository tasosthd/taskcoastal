{
  "buildCommand": "echo 'Static assets ready'",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/",
      "destination": "/c/index.html"
    },
    {
      "source": "/c",
      "destination": "/c/index.html"
    },
    {
      "source": "/c/",
      "destination": "/c/index.html"
    },
    {
      "source": "/c/:path*",
      "destination": "/c/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
